    <a href="/P3224/contact-html" class="bg-white text-brand-accent font-bold px-8 py-3 rounded-full text-sm hover:bg-accent-light transition-colors inline-block">Contact Us</a>
  </div>
</section>

<!-- Map -->
<section class="py-16 bg-white">
  <div class="max-w-6xl mx-auto px-4">
    <h2 class="text-2xl font-extrabold text-brand-accent mb-6 text-center">Where to Find Us</h2>
    <div class="rounded-2xl overflow-hidden shadow-lg border border-border">
