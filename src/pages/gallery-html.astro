    </div>
    <div>
      <h3 class="font-extrabold text-base mb-4">Get In Touch</h3>
      <ul class="space-y-2 text-sm text-white/80">
        <li><a href="tel:+441342323833" class="hover:text-white transition-colors">📞 01342 323 833</a></li>
        <li><a href="mailto:info@alpinehotelforcats.co.uk" class="hover:text-white transition-colors">✉️ info@alpinehotelforcats.co.uk</a></li>
        <li>📍 {address}</li>
      </ul>
    </div>
  </div>
  <div class="max-w-6xl mx-auto px-4 mt-8 pt-8 border-t border-white/20 text-center text-xs text-white/50">
